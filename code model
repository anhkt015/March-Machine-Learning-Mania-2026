def compute_winrate(df, gender):
    wins = df.groupby(["Season","WTeamID"]).size()
    losses = df.groupby(["Season","LTeamID"]).size()
    winrate = (wins / (wins.add(losses, fill_value=0))).reset_index()
    winrate.rename(columns={"WTeamID":"TeamID",0:"WinRate"}, inplace=True)
    winrate["Gender"] = gender
    return winrate

