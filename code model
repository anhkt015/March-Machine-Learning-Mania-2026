import pandas as pd

# Hàm tính WinRate theo mùa
def compute_winrate(file, season_col="Season", wteam_col="WTeamID", lteam_col="LTeamID", season=2026):
    games = pd.read_csv(file)
    games_season = games[games[season_col] == season]
    
    wins = games_season.groupby(wteam_col).size().reset_index(name="Wins")
    losses = games_season.groupby(lteam_col).size().reset_index(name="Losses")
    
    stats = pd.merge(wins, losses, left_on=wteam_col, right_on=lteam_col, how="outer").fillna(0)
    stats["TeamID"] = stats[wteam_col].combine_first(stats[lteam_col])
    stats["Wins"] = stats["Wins"].astype(int)
    stats["Losses"] = stats["Losses"].astype(int)
    stats["WinRate"] = stats["Wins"] / (stats["Wins"] + stats["Losses"])
    
    return stats[["TeamID","Wins","Losses","WinRate"]]

